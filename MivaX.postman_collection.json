{
  "info": {
    "_postman_id": "8b989c0c-3c5d-4d07-88cb-ee3bc2d3dc18",
    "name": "MivaX API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{email}}\",\n    \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Exchanges LMS credentials for a Session ID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Student (SIS)",
      "item": [
        {
          "name": "User Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["user", "{{sessionId}}"]
            },
            "description": "Fetch basic student profile from SIS."
          },
          "response": []
        },
        {
          "name": "Academic Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/student/academic-summary/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["student", "academic-summary", "{{sessionId}}"]
            },
            "description": "Get overall CGPA and degree status."
          },
          "response": []
        },
        {
          "name": "Academic Levels",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/student/academic-levels/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["student", "academic-levels", "{{sessionId}}"]
            },
            "description": "List all study years (100L, 200L, etc) with completion summaries."
          },
          "response": []
        },
        {
          "name": "Full Transcript (All Levels)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/student/transcript/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["student", "transcript", "{{sessionId}}"]
            },
            "description": "Returns results for all academic levels at once."
          },
          "response": []
        },
        {
          "name": "Transcript (Level Specific)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/student/transcript/200_LEVEL/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["student", "transcript", "200_LEVEL", "{{sessionId}}"]
            },
            "description": "Detailed results and GPA for a specific level (e.g., 200_LEVEL)."
          },
          "response": []
        },
        {
          "name": "Current Courses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/student/current-courses/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["student", "current-courses", "{{sessionId}}"]
            },
            "description": "List only the courses currently being taken in the active semester."
          },
          "response": []
        },
        {
          "name": "Registration Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/student/registration-status/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["student", "registration-status", "{{sessionId}}"]
            },
            "description": "Check enrollment windows and pending status."
          },
          "response": []
        },
        {
          "name": "Payment Records",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payment-records/{{sessionId}}?page=1&perPage=10",
              "host": ["{{baseUrl}}"],
              "path": ["payment-records", "{{sessionId}}"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "perPage",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Notifications",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications/{{sessionId}}?page=1&perPage=5",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "{{sessionId}}"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "perPage",
                  "value": "5"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Full Dashboard (Raw)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/dashboard/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "{{sessionId}}"]
            },
            "description": "Fetch the entire SIS dashboard JSON (heavy)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "LMS",
      "item": [
        {
          "name": "Courses List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/courses/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["courses", "{{sessionId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Course Content",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/course/{{courseId}}/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["course", "{{courseId}}", "{{sessionId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Module Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/mod/{{modType}}/{{modId}}/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["mod", "{{modType}}", "{{modId}}", "{{sessionId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Image Proxy",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/img/{{encodedUrl}}/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["img", "{{encodedUrl}}", "{{sessionId}}"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://mivax.marvelly.com.ng",
      "type": "string"
    },
    {
      "key": "email",
      "value": "your.email@miva.edu.ng",
      "type": "string"
    },
    {
      "key": "password",
      "value": "your_password",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "your_session_id_here",
      "type": "string"
    },
    {
      "key": "courseId",
      "value": "123",
      "type": "string"
    },
    {
      "key": "modId",
      "value": "456",
      "type": "string"
    },
    {
      "key": "modType",
      "value": "page",
      "type": "string"
    },
    {
      "key": "encodedUrl",
      "value": "base64_encoded_image_url",
      "type": "string"
    }
  ]
}
